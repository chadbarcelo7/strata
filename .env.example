# ─── Copy this file to .env and fill in your values ───────────────────────────

# Flask
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development          # use "production" in prod
FLASK_DEBUG=1

# MySQL  (must create this DB first: CREATE DATABASE audio_stems;)
DB_USER=root
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=3306
DB_NAME=audio_stems

# Redis / Celery (needed for background separation jobs)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Demucs model to use  (options: htdemucs, htdemucs_ft, mdx, mdx_extra)
DEMUCS_MODEL=htdemucs

# Max upload size in MB
MAX_UPLOAD_MB=100
